let mapleader=" "

set clipboard=unnamedplus
set hlsearch
set showmode
set so=5
set incsearch
set ignorecase
set smartcase
set nu

Plug 'machakann/vim-highlightedyank'
Plug 'preservim/nerdtree'
Plug 'justinmk/vim-sneak'
Plug 'tpope/vim-surround'

nnoremap <Esc> :nohlsearch<CR>

nmap <leader>ff <Action>(GotoFile)
nmap <leader>fr <Action>(RecentFiles)

nmap <leader>p :action GotoAction<CR>

nmap <leader>sg :action FindInPath<CR>
nmap <leader>sf :action Find<CR>
nmap <leader>ss <Action>(SearchEverywhere)

nmap <leader>gc <Action>(ActivateCommitToolWindow)
nmap <leader>gg <Action>(Git.Branches)

nmap <leader>ca :action ShowIntentionActions<CR>
nmap <leader>cg :action Generate<CR>
nmap <leader>cf :action ReformatCode<CR>
nmap <leader>cr :action RenameElement<CR>
nmap <leader>cc <Action>(ActivateGitHubCopilotChatToolWindow)

nmap <leader>tt <Action>(ActivateTerminalToolWindow)

nmap gd :action GotoDeclaration<CR>
nmap gD :action GotoSuperMethod<CR>
nmap gr :action FindUsages<CR>
nmap gi :action GotoImplementation<CR>
nmap K :action QuickJavaDoc<CR>

vmap J :action MoveLineDown<CR>
vmap K :action MoveLineUp<CR>

